<Window x:Class="AppMantenimiento.LecturasWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Registro de Lecturas y Mantenimiento"
        Height="780" Width="1150"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5">

    <Window.Resources>
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#546E7A"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="InputStyle" TargetType="Control">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#CFD8DC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Height" Value="36"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E3F2FD"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="68"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#1A237E" Offset="0"/>
                    <GradientStop Color="#283593" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="20,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📋" FontSize="28" VerticalAlignment="Center" Margin="0,0,14,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Registro de Lecturas y Mantenimiento"
                                   FontSize="17" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Pantalla de supervisor — Historial exportable para auditoría"
                                   FontSize="11" Foreground="#9FA8DA"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ FORMULARIO ═══ -->
        <Border Grid.Row="1" Background="White" Margin="14,12,14,0"
        CornerRadius="8" Padding="20,16">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08"/>
            </Border.Effect>

            <StackPanel>
                <Border x:Name="PanelModoEdicion"
                    Background="#111111"
                    BorderBrush="#FFD600"
                    BorderThickness="2"
                    CornerRadius="6"
                    Padding="12,8"
                    Margin="0,0,0,12">
                    <TextBlock x:Name="TxtModoEdicion"
                       Text="Modo alta de registro"
                       Foreground="#FFD600"
                       FontWeight="Bold"
                       FontSize="13"/>
                </Border>

                <!-- Selector tipo -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                    <TextBlock Text="Tipo de registro:" Style="{StaticResource LabelStyle}"
                       VerticalAlignment="Center" Margin="0,0,16,0" FontSize="13"/>
                    <RadioButton x:Name="RbLectura" Content="📊  Lectura / Valor numérico"
                         IsChecked="True" VerticalAlignment="Center" FontSize="13"
                         Margin="0,0,24,0" Checked="TipoRegistro_Changed"/>
                    <RadioButton x:Name="RbMantenimiento" Content="🔧  Observación / Mantenimiento"
                         VerticalAlignment="Center" FontSize="13"
                         Checked="TipoRegistro_Changed"/>
                </StackPanel>

                <!-- Fila 1: Equipo + Valor + Coste + Proveedor + Botón -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="85"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="85"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="150"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="EQUIPO" Style="{StaticResource LabelStyle}"/>
                        <ComboBox x:Name="CmbEquipo" Style="{StaticResource InputStyle}"
                        DisplayMemberPath="Nombre" SelectedValuePath="Id"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock x:Name="LblValor" Text="VALOR (h / km)"
                        Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="TxtValor" Style="{StaticResource InputStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="COSTE (€)" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="TxtCoste" Style="{StaticResource InputStyle}" Text="0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="6">
                        <TextBlock Text="PROVEEDOR (opcional)" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="TxtProveedor" Style="{StaticResource InputStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="8" VerticalAlignment="Bottom">
                        <Button x:Name="BtnLimpiar" Content="🧹 Limpiar"
                        Style="{StaticResource BtnBase}"
                        Background="#78909C"
                        Padding="10,0"
                        Height="34"
                        Click="BtnLimpiar_Click"/>
                    </StackPanel>

                    <StackPanel Grid.Column="10" VerticalAlignment="Bottom">
                        <Button x:Name="BtnBorrar" Content="🗑 Borrar"
                        Style="{StaticResource BtnBase}"
                        Background="#C62828"
                        Padding="10,0"
                        Height="34"
                        Click="BtnBorrar_Click"/>
                    </StackPanel>

                    <StackPanel Grid.Column="12" VerticalAlignment="Bottom">
                        <Button x:Name="BtnRegistrar" Content="✔ Registrar"
                        Style="{StaticResource BtnBase}"
                        Background="#2E7D32"
                        Padding="12,0"
                        MinWidth="140"
                        Height="34"
                        Click="BtnRegistrar_Click"/>    
                    </StackPanel>
                </Grid>

                <!-- Descripción amplia -->
                <StackPanel Margin="0,0,0,10">
                    <TextBlock x:Name="LblDescripcion" Text="DESCRIPCIÓN (opcional)"
                       Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="TxtDescripcion"
                     Height="58" Padding="10,8" FontSize="13"
                     BorderBrush="#CFD8DC" BorderThickness="1"
                     Background="White" TextWrapping="Wrap"
                     AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                </StackPanel>

                <!-- ══ PANEL RESET CONTADOR (solo visible en modo Mantenimiento) ══ -->
                <Border x:Name="PanelReset" Visibility="Collapsed"
                Background="#FFF8E1" CornerRadius="6"
                Padding="16,12" BorderBrush="#FFE082" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="🔄  Resetear contador de mantenimiento"
                               FontWeight="Bold" Foreground="#E65100" FontSize="13"
                               Margin="0,0,0,4"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#5D4037"
                               Text="Si el operario ha avisado de que se llegó al límite (ej. 500 h), usa este botón para confirmar que el mantenimiento se ha realizado. El sistema actualizará la fecha y reiniciará el contador."/>
                            <CheckBox x:Name="ChkResetContador" Margin="0,8,0,0"
                              FontSize="12" FontWeight="SemiBold" Foreground="#BF360C"
                              Content="✅  Marcar como COMPLETADO y resetear el contador de este equipo"/>
                        </StackPanel>

                        <Border Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                            <Button Content="⚡  Confirmar reset"
                            Style="{StaticResource BtnBase}"
                            Background="#E65100" Padding="14,0"
                            Height="38" Click="BtnResetContador_Click"/>
                        </Border>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <!-- ═══ HISTORIAL ═══ -->
        <Border Grid.Row="2" Background="White" Margin="14,10,14,14" CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Barra de filtros -->
                <Border Grid.Row="0" Background="#FAFAFA" CornerRadius="8,8,0,0"
                        BorderBrush="#ECEFF1" BorderThickness="0,0,0,1" Padding="16,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Filtros izquierda -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="Historial" FontSize="14" FontWeight="SemiBold"
                                       Foreground="#263238" VerticalAlignment="Center"/>
                            <Border Background="#1A237E" CornerRadius="10" Padding="10,2" Margin="10,0,20,0">
                                <TextBlock x:Name="TxtContador" Text="0" Foreground="White"
                                           FontSize="11" FontWeight="SemiBold"/>
                            </Border>

                            <TextBlock Text="Máquina:" FontSize="12" Foreground="#546E7A"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="CmbFiltroEquipo" Width="180" Height="28" FontSize="12"
                                      DisplayMemberPath="Nombre" SelectedValuePath="Id"
                                      SelectionChanged="Filtro_Changed"/>

                            <TextBlock Text="Tipo:" FontSize="12" Foreground="#546E7A"
                                       VerticalAlignment="Center" Margin="16,0,8,0"/>
                            <ComboBox x:Name="CmbFiltroTipo" Width="170" Height="28" FontSize="12"
                                      SelectionChanged="Filtro_Changed">
                                <ComboBoxItem Content="Todos los registros" IsSelected="True"/>
                                <ComboBoxItem Content="Solo lecturas"/>
                                <ComboBoxItem Content="Solo mantenimientos"/>
                            </ComboBox>
                        </StackPanel>

                        <!-- Botón exportar derecha -->
                        <Button Grid.Column="2" Content="📥  Exportar CSV"
                                Style="{StaticResource BtnBase}"
                                Background="#1565C0" Padding="14,0"
                                Height="30" Click="BtnExportarCSV_Click"/>
                    </Grid>
                </Border>

                <!-- DataGrid -->
                <DataGrid Grid.Row="1" x:Name="GridLecturas"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" CanUserResizeRows="False"
                          CanUserSortColumns="True"
                          Sorting="GridLecturas_Sorting"
                          SelectionChanged="GridLecturas_SelectionChanged"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#F0F4F8"
                          BorderThickness="0" FontSize="13"
                          AlternatingRowBackground="#F8FAFB"
                          RowBackground="White"
                          SelectionMode="Single"
                          ColumnHeaderHeight="38">      

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#FAFAFA"/>
                            <Setter Property="Foreground" Value="#546E7A"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="Padding" Value="12,0"/>
                            <Setter Property="BorderBrush" Value="#E0E0E0"/>
                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="12,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#B0BEC5"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="TIPO" Width="145" SortMemberPath="Tipo">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="8,3"
                                            HorizontalAlignment="Left" Margin="8,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#E8F5E9"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Tipo}" Value="Mantenimiento">
                                                        <Setter Property="Background" Value="#FFF3E0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Tipo}" FontSize="12" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Tipo}" Value="Mantenimiento">
                                                            <Setter Property="Foreground" Value="#E65100"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="EQUIPO" Binding="{Binding NombreEquipo}" Width="160" SortMemberPath="NombreEquipo">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="8,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="VALOR" Binding="{Binding Valor}" Width="80" SortMemberPath="Valor">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="8,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="#1565C0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="DESCRIPCIÓN / ACTUACIÓN" Binding="{Binding Descripcion}" Width="*" SortMemberPath="Descripcion">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="8,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="COSTE (€)" Binding="{Binding Coste, StringFormat=N2}" Width="90" SortMemberPath="Coste">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="8,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Foreground" Value="#6A1B9A"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="FECHA" Binding="{Binding Fecha}" Width="130" SortMemberPath="Fecha">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="8,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#546E7A"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="PROVEEDOR" Binding="{Binding Proveedor}" Width="160" SortMemberPath="Proveedor">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="8,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#455A64"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="REGISTRADO POR" Binding="{Binding Operario}" Width="130" SortMemberPath="Operario">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="8,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#455A64"/>
                                    <Setter Property="FontStyle" Value="Italic"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Barra inferior: coste total visible -->
                <Border Grid.Row="2" Background="#F5F5F5" BorderBrush="#ECEFF1"
                        BorderThickness="0,1,0,0" Padding="16,8" CornerRadius="0,0,8,8">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="Coste total filtrado:" FontSize="12"
                                   Foreground="#546E7A" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="TxtCosteTotal" Text="0,00 €"
                                   FontSize="14" FontWeight="Bold" Foreground="#6A1B9A"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>