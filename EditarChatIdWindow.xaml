<Window x:Class="AppMantenimiento.EditarChatIdWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editar Telegram Chat ID" Height="200" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F0F4F8">
    <StackPanel Margin="24,20">
        <TextBlock x:Name="TxtTitulo" FontSize="13" FontWeight="SemiBold"
                   Foreground="#1E3A5F" Margin="0,0,0,12"/>
        <TextBlock FontSize="11" Foreground="#5A6375" Margin="0,0,0,4">
            Chat ID (el operario debe pulsar /start en el bot primero)
        </TextBlock>
        <TextBox x:Name="TxtChatId" Height="32" Padding="8,4"
                 BorderBrush="#D0D7E3" BorderThickness="1"
                 Background="White" FontSize="13"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancelar" Width="90" Height="32" Margin="0,0,8,0"
                    Background="#6C757D" Foreground="White" BorderThickness="0"
                    Click="BtnCancelar_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="10,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="Guardar" Width="90" Height="32"
                    Background="#059669" Foreground="White" BorderThickness="0"
                    Click="BtnGuardar_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="10,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </StackPanel>
</Window>