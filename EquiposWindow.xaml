<Window x:Class="AppMantenimiento.EquiposWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🔧 Gestión de Equipos" Height="680" Width="1050"
        WindowStartupLocation="CenterOwner" Background="#F0F4F8">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#5A6375"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderBrush" Value="#D0D7E3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- Estilo botón acción -->
        <Style x:Key="BtnAccion" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- CABECERA -->
        <Border Grid.Row="0" Background="#1B4F72" CornerRadius="10"
                Padding="18,12" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🔧" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Gestión de Equipos" FontSize="18" FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="Alta, consulta, baja y eliminación de equipos industriales"
                               FontSize="11" Foreground="#A8C8E0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- FORMULARIO DE ALTA -->
        <Border Grid.Row="1" Background="White" CornerRadius="10"
                Padding="18,14" Margin="0,0,0,14">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.08"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Nombre del equipo" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="TxtNombre" Style="{StaticResource InputStyle}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="Ubicación" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="TxtUbicacion" Style="{StaticResource InputStyle}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,10,0">
                    <TextBlock Text="Descripción" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="TxtDescripcion" Style="{StaticResource InputStyle}"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="0,0,10,0">
                    <TextBlock Text="⏱ Frec. (horas)" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="TxtFrecHoras" Style="{StaticResource InputStyle}"
                             ToolTip="Frecuencia de mantenimiento en horas de trabajo"/>
                </StackPanel>

                <StackPanel Grid.Column="4" Margin="0,0,10,0">
                    <TextBlock Text="🛣 Frec. (km)" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="TxtFrecKm" Style="{StaticResource InputStyle}"
                             ToolTip="Frecuencia de mantenimiento por kilómetros"/>
                </StackPanel>

                <Button Grid.Column="5" x:Name="BtnAgregar"
                        Style="{StaticResource BtnAccion}"
                        Content="➕ Agregar equipo"
                        VerticalAlignment="Bottom" Margin="0,0,0,0"
                        Click="BtnAgregar_Click">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#1A8754" Offset="0"/>
                            <GradientStop Color="#20C997" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
            </Grid>
        </Border>

        <!-- TABLA -->
        <Border Grid.Row="2" Background="White" CornerRadius="10" Padding="0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.08"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Filtro activos/todos -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="16,12,16,8">
                    <TextBlock Text="Mostrar:" FontSize="12" FontWeight="SemiBold"
                               VerticalAlignment="Center" Foreground="#5A6375" Margin="0,0,8,0"/>
                    <RadioButton x:Name="RbActivos" Content="Solo activos" IsChecked="True"
                                 FontSize="12" Margin="0,0,12,0" VerticalAlignment="Center"
                                 Checked="FiltroChanged"/>
                    <RadioButton x:Name="RbTodos" Content="Todos (incl. bajas)"
                                 FontSize="12" VerticalAlignment="Center"
                                 Checked="FiltroChanged"/>
                </StackPanel>

                <DataGrid Grid.Row="1" x:Name="GridEquipos"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" CanUserResizeRows="False"
                          RowHeight="38" HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0"
                          AlternatingRowBackground="#F8FBFF"
                          SelectionMode="Single"
                          Margin="0,0,0,0">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#EEF2F7"/>
                            <Setter Property="Foreground" Value="#374151"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#D0D7E3"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                        <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="180"/>
                        <DataGridTextColumn Header="Ubicación" Binding="{Binding Ubicacion}" Width="140"/>
                        <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="160"/>
                        <DataGridTextColumn Header="⏱ Horas" Binding="{Binding FrecuenciaHoras}" Width="80"/>
                        <DataGridTextColumn Header="🛣 Km" Binding="{Binding FrecuenciaKm}" Width="80"/>
                        <DataGridTextColumn Header="Última lectura" Binding="{Binding UltimaLectura}" Width="110"/>
                        <DataGridTemplateColumn Header="Estado" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10" Padding="6,2"
                                            HorizontalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#D1FAE5"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Activo}" Value="0">
                                                        <Setter Property="Background" Value="#FEE2E2"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock HorizontalAlignment="Center" FontSize="11" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="✅ Activo"/>
                                                    <Setter Property="Foreground" Value="#065F46"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Activo}" Value="0">
                                                            <Setter Property="Text" Value="🔴 Baja"/>
                                                            <Setter Property="Foreground" Value="#991B1B"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- BARRA DE ACCIONES -->
                <Border Grid.Row="2" Background="#F8FBFF" CornerRadius="0,0,10,10"
                        Padding="16,10" BorderThickness="0,1,0,0" BorderBrush="#E5EAF1">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock x:Name="TxtSeleccionado" Text="Selecciona un equipo de la tabla"
                                   FontSize="12" Foreground="#6B7280" VerticalAlignment="Center"
                                   Margin="0,0,16,0"/>
                        <Button Style="{StaticResource BtnAccion}"
                                Content="⬇️ Dar de baja" Margin="0,0,8,0"
                                Click="BtnDarDeBaja_Click">
                            <Button.Background>
                                <SolidColorBrush Color="#D97706"/>
                            </Button.Background>
                        </Button>
                        <Button Style="{StaticResource BtnAccion}"
                                Content="🔺 Reactivar" Margin="0,0,8,0"
                                Click="BtnReactivar_Click">
                            <Button.Background>
                                <SolidColorBrush Color="#059669"/>
                            </Button.Background>
                        </Button>
                        <Button Style="{StaticResource BtnAccion}"
                                Content="🗑 Eliminar definitivo"
                                Click="BtnEliminar_Click">
                            <Button.Background>
                                <SolidColorBrush Color="#DC2626"/>
                            </Button.Background>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>