<Window x:Class="AppMantenimiento.OperariosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestión de Operarios" Height="620" Width="860"
        WindowStartupLocation="CenterOwner"
        Background="#F0F4F8">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Grid.Row="0" Text="👷 Gestión de Operarios"
                   FontSize="20" FontWeight="Bold" Foreground="#2C3E50"
                   Margin="0,0,0,12"/>

        <!-- Formulario alta -->
        <Border Grid.Row="1" Background="White" CornerRadius="8"
                Padding="16" Margin="0,0,0,12"
                BorderBrush="#DDE3EA" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Column="0" Text="Nombre *" FontSize="11"
                           Foreground="#666" Margin="0,0,8,2"/>
                <TextBlock Grid.Column="1" Text="Teléfono" FontSize="11"
                           Foreground="#666" Margin="0,0,8,2"/>
                <TextBlock Grid.Column="2" Text="Email" FontSize="11"
                           Foreground="#666" Margin="0,0,8,2"/>
                <TextBlock Grid.Column="3" Text="Rol" FontSize="11"
                           Foreground="#666" Margin="0,0,8,2"/>

                <TextBox x:Name="TxtNombre" Grid.Row="1" Grid.Column="0"
                         Height="32" Padding="8,4" Margin="0,0,8,0"
                         BorderBrush="#BDC3CA" BorderThickness="1"/>
                <TextBox x:Name="TxtTelefono" Grid.Row="1" Grid.Column="1"
                         Height="32" Padding="8,4" Margin="0,0,8,0"
                         BorderBrush="#BDC3CA" BorderThickness="1"/>
                <TextBox x:Name="TxtEmail" Grid.Row="1" Grid.Column="2"
                         Height="32" Padding="8,4" Margin="0,0,8,0"
                         BorderBrush="#BDC3CA" BorderThickness="1"/>

                <ComboBox x:Name="CmbRol" Grid.Row="1" Grid.Column="3"
                          Height="32" Margin="0,0,8,0" SelectedIndex="0">
                    <ComboBoxItem Content="Operario"/>
                    <ComboBoxItem Content="Supervisor"/>
                    <ComboBoxItem Content="Admin"/>
                </ComboBox>

                <Button Grid.Row="1" Grid.Column="4" Content="➕ Agregar"
                        Height="32" Padding="14,0"
                        Background="#27AE60" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Click="BtnAgregar_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <!-- Filtro y tabla -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Filtro activos/todos -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="Mostrar:" VerticalAlignment="Center"
                           Margin="0,0,8,0" Foreground="#555"/>
                <RadioButton x:Name="RbActivos" Content="Solo activos"
                             IsChecked="True" Margin="0,0,12,0"
                             Checked="FiltroChanged"/>
                <RadioButton Content="Todos" Checked="FiltroChanged"/>
            </StackPanel>

            <!-- DataGrid -->
            <DataGrid x:Name="GridOperarios" Grid.Row="1"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      Background="White"
                      BorderBrush="#DDE3EA" BorderThickness="1"
                      RowBackground="White"
                      AlternatingRowBackground="#F8FAFC"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#EEF0F2"
                      HeadersVisibility="Column"
                      CanUserResizeRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"     Binding="{Binding Id}"      Width="45"/>
                    <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}"  Width="*"/>
                    <DataGridTextColumn Header="Teléfono" Binding="{Binding Telefono}" Width="110"/>
                    <DataGridTextColumn Header="Email"  Binding="{Binding Email}"   Width="180"/>
                    <DataGridTextColumn Header="Rol"    Binding="{Binding Rol}"     Width="90"/>
                    <DataGridTextColumn Header="Activo" Binding="{Binding Activo}"  Width="60"/>
                    <DataGridTextColumn Header="Chat ID" Binding="{Binding TelegramChatId}" Width="110"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Botones de acción -->
        <WrapPanel Grid.Row="3" Margin="0,12,0,0" HorizontalAlignment="Left">
            <Button Content="🔕 Dar de baja" Height="34" Padding="14,0"
                    Margin="0,0,8,0" Background="#E67E22" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnDarDeBaja_Click"/>
            <Button Content="✅ Reactivar" Height="34" Padding="14,0"
                    Margin="0,0,8,0" Background="#27AE60" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnReactivar_Click"/>
            <Button Content="🗑 Eliminar" Height="34" Padding="14,0"
                    Margin="0,0,8,0" Background="#E74C3C" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnEliminar_Click"/>
            <Button Content="💬 Editar Chat ID" Height="34" Padding="14,0"
                    Margin="0,0,8,0" Background="#2980B9" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnEditarChatId_Click"/>
            <Button Content="📨 Probar Telegram" Height="34" Padding="14,0"
                    Background="#8E44AD" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnProbarTelegram_Click"/>
        </WrapPanel>

    </Grid>
</Window>