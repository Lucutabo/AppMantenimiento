<Window x:Class="AppMantenimiento.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sistema de Mantenimiento" Height="650" Width="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F0F4F8">

    <Window.Resources>
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Height" Value="56"/>
            <Setter Property="Width" Value="360"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="16,0">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.72"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="130"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- CABECERA -->
        <Border Grid.Row="0" CornerRadius="0,0,28,28">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1B4F72" Offset="0"/>
                    <GradientStop Color="#2E86C1" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="⚙" FontSize="32" Foreground="White"
                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="Sistema de Mantenimiento"
                           FontSize="19" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Gestión industrial de equipos y operarios"
                           FontSize="11" Foreground="#B3D9F2"
                           HorizontalAlignment="Center" Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <!-- SELECTOR DE ROL -->
        <Border Grid.Row="1" Margin="35,8,35,8" Background="White"
                CornerRadius="10" Padding="14,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.10"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock Text="👤  Rol actual:" FontSize="13" FontWeight="SemiBold"
                           VerticalAlignment="Center" Foreground="#2C3E50" Margin="0,0,10,0"/>
                <ComboBox x:Name="CmbRol" Width="160" Height="30"
                          SelectedIndex="0" FontSize="13"
                          BorderBrush="#2E86C1" BorderThickness="1.5">
                    <ComboBoxItem Content="Operario"/>
                    <ComboBoxItem Content="Supervisor"/>
                    <ComboBoxItem Content="Administrador"/>
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- BOTONES -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Disabled">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="0,15,0,20">
                <Button Content="Dashboard - Estado equipos" Width="260" Height="36"
                        Margin="0,0,0,10" Background="#1A1A2E" Foreground="White"
                        BorderThickness="0" FontWeight="SemiBold"
                        Click="BtnDashboardClick"/>     

                <Button Style="{StaticResource MenuButton}" Click="BtnEquipos_Click">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#1A8754" Offset="0"/>
                            <GradientStop Color="#20C997" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔧" FontSize="20" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Gestión de Equipos" FontWeight="Bold" FontSize="13"/>
                            <TextBlock Text="Alta, edición y seguimiento" FontSize="10" Opacity="0.85"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource MenuButton}" Click="BtnOperarios_Click">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#0D6EFD" Offset="0"/>
                            <GradientStop Color="#6EA8FE" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="👷" FontSize="20" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Gestión de Operarios" FontWeight="Bold" FontSize="13"/>
                            <TextBlock Text="Personal y roles asignados" FontSize="10" Opacity="0.85"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource MenuButton}" Click="BtnAsignaciones_Click">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#7B2FBE" Offset="0"/>
                            <GradientStop Color="#C77DFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔗" FontSize="20" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Asignaciones" FontWeight="Bold" FontSize="13"/>
                            <TextBlock Text="Vincular equipos a operarios" FontSize="10" Opacity="0.85"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource MenuButton}" Click="BtnLecturas_Click">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#E67E22" Offset="0"/>
                            <GradientStop Color="#F8C471" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📋" FontSize="20" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Registro de Lecturas" FontWeight="Bold" FontSize="13"/>
                            <TextBlock Text="Historial de mantenimientos" FontSize="10" Opacity="0.85"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource MenuButton}" Click="BtnConfiguracion_Click">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#495057" Offset="0"/>
                            <GradientStop Color="#ADB5BD" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚙️" FontSize="20" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Configuración" FontWeight="Bold" FontSize="13"/>
                            <TextBlock Text="SMTP, WhatsApp y ajustes" FontSize="10" Opacity="0.85"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>