<Window x:Class="AppMantenimiento.ConfiguracionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuración del Sistema" Height="660" Width="680"
        WindowStartupLocation="CenterOwner" Background="#F0F4F8">

    <Window.Resources>
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#5A6375"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderBrush" Value="#D0D7E3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style x:Key="BtnStyle" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- 0: Cabecera -->
                <RowDefinition Height="Auto"/>
                <!-- 1: SMTP -->
                <RowDefinition Height="Auto"/>
                <!-- 2: Telegram -->
                <RowDefinition Height="Auto"/>
                <!-- 3: Umbrales -->
                <RowDefinition Height="*"/>
                <!-- 4: Espacio flexible -->
                <RowDefinition Height="Auto"/>
                <!-- 5: Botones -->
            </Grid.RowDefinitions>

            <!-- CABECERA -->
            <Border Grid.Row="0" CornerRadius="10" Padding="18,12" Margin="0,0,0,16">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0D6EFD" Offset="0"/>
                        <GradientStop Color="#0B5ED7" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <TextBlock Text="Configuración del Sistema" FontSize="20"
                       FontWeight="Bold" Foreground="White"/>
            </Border>

            <!-- BLOQUE SMTP -->
            <Border Grid.Row="1" Background="White" CornerRadius="10"
                Padding="18,14" Margin="0,0,0,12">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.08"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Correo electrónico SMTP" FontSize="13"
                           FontWeight="Bold" Foreground="#1E3A5F" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Servidor SMTP" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="TxtSmtpServidor" Style="{StaticResource InputStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Puerto" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="TxtSmtpPuerto" Style="{StaticResource InputStyle}"/>
                        </StackPanel>
                    </Grid>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Email remitente" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="TxtSmtpEmail" Style="{StaticResource InputStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                            <TextBlock Text="Contraseña SMTP" Style="{StaticResource LabelStyle}"/>
                            <PasswordBox x:Name="TxtSmtpPassword" Height="32" Padding="8,4"
                                     BorderBrush="#D0D7E3" BorderThickness="1" FontSize="13"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Email del Supervisor" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="TxtEmailSupervisor" Style="{StaticResource InputStyle}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- BLOQUE TELEGRAM -->
            <Border Grid.Row="2" Background="White" CornerRadius="10"
                Padding="18,14" Margin="0,0,0,12">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.08"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Telegram Bot" FontSize="13"
                           FontWeight="Bold" Foreground="#1E3A5F" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Token del Bot" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="TxtTelegramToken" Style="{StaticResource InputStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Chat ID del Supervisor" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="TxtTelegramChatSupervisor" Style="{StaticResource InputStyle}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- BLOQUE UMBRALES + SCHEDULER + BACKUP -->
            <Border Grid.Row="3" Background="White" CornerRadius="10"
                Padding="18,14" Margin="0,0,0,12">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.08"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Umbrales de alerta en Dashboard" FontSize="13"
                           FontWeight="Bold" Foreground="#1E3A5F" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Umbral AVISO (horas/km restantes)"
                                   Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="TxtUmbralAviso" Style="{StaticResource InputStyle}"
                                 ToolTip="Estado AVISO cuando quedan menos de este valor"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Umbral CRÍTICO (horas/km restantes)"
                                   Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="TxtUmbralCritico" Style="{StaticResource InputStyle}"
                                 ToolTip="Estado CRÍTICO cuando quedan menos de este valor"/>
                        </StackPanel>
                    </Grid>

                    <!-- SCHEDULER DE AVISOS -->
                    <Border Background="White" CornerRadius="8" Padding="20,16" Margin="0,12,0,14">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="AVISOS AUTOMÁTICOS (SCHEDULER)" FontSize="11" FontWeight="Bold"
                                   Foreground="#546E7A" Margin="0,0,0,12"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="INTERVALO DE COMPROBACIÓN (días)"
                                           Style="{StaticResource LabelStyle}"/>
                                    <TextBox x:Name="TxtSchedulerIntervalo" Style="{StaticResource InputStyle}"
                                         ToolTip="Cada cuántos días el sistema comprueba y envía avisos. Recomendado: 1"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                    <TextBlock Text="SCHEDULER ACTIVO" Style="{StaticResource LabelStyle}"/>
                                    <ComboBox x:Name="CmbSchedulerActivo" Height="32" FontSize="13"
                                          BorderBrush="#CFD8DC" BorderThickness="1">
                                        <ComboBoxItem Content="Sí — enviar avisos automáticos" Tag="1"/>
                                        <ComboBoxItem Content="No — desactivado" Tag="0"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="0,0,10,0">
                                    <TextBlock Text="DÍAS SIN LECTURA PARA AVISAR"
                                           Style="{StaticResource LabelStyle}"/>
                                    <TextBox x:Name="TxtDiasSinLectura" Style="{StaticResource InputStyle}"
                                         ToolTip="Días sin registrar lectura antes de solicitar al operario. Por defecto: 15"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3" VerticalAlignment="Bottom">
                                    <Button x:Name="BtnTestScheduler" Content="▶  Ejecutar ahora"
                                        Style="{StaticResource BtnStyle}" Background="#6A1B9A"
                                        Width="130" Click="BtnTestScheduler_Click"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Cada día el sistema comprobará si algún equipo está próximo a vencer o vencido y enviará avisos por Telegram y email."
                                   FontSize="11" Foreground="#90A4AE" TextWrapping="Wrap" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- COPIA DE SEGURIDAD -->
                    <Border Background="White" CornerRadius="8" Padding="20,16" Margin="0,0,0,14">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="COPIA DE SEGURIDAD" FontSize="11" FontWeight="Bold"
                                   Foreground="#546E7A" Margin="0,0,0,12"/>

                            <!-- Backup -->
                            <Border Background="#E8F5E9" CornerRadius="6" Padding="14,10" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Exportar copia de seguridad"
                                               FontWeight="SemiBold" Foreground="#2E7D32" FontSize="13"/>
                                        <TextBlock Text="Guarda la base de datos en la ubicación que elijas (disco externo, carpeta, etc.)"
                                               FontSize="11" Foreground="#795548" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" x:Name="BtnBackup" Content="💾  Exportar backup"
                                        Style="{StaticResource BtnBase}" Background="#2E7D32"
                                        Padding="16,0" Height="36" Margin="16,0,0,0"
                                        Click="BtnBackup_Click"/>
                                </Grid>
                            </Border>

                            <!-- Restaurar -->
                            <Border Background="#FFF3E0" CornerRadius="6" Padding="14,10" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Restaurar copia de seguridad"
                                               FontWeight="SemiBold" Foreground="#E65100" FontSize="13"/>
                                        <TextBlock Text="⚠️ Reemplaza toda la base de datos actual. La aplicación se reiniciará."
                                               FontSize="11" Foreground="#795548" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" x:Name="BtnRestaurar" Content="📂  Restaurar backup"
                                        Style="{StaticResource BtnBase}" Background="#E65100"
                                        Padding="16,0" Height="36" Margin="16,0,0,0"
                                        Click="BtnRestaurar_Click"/>
                                </Grid>
                            </Border>

                            <!-- ── NUEVO: Limpiar base de datos ── -->
                            <Border Background="#FFEBEE" CornerRadius="6" Padding="14,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Limpiar base de datos"
                                               FontWeight="SemiBold" Foreground="#B71C1C" FontSize="13"/>
                                        <TextBlock Text="🗑️ Borra TODOS los datos (equipos, operarios, lecturas). Conserva la configuración. La app se reiniciará."
                                               FontSize="11" Foreground="#795548" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" x:Name="BtnLimpiarBD" Content="🗑️  Limpiar todo"
                                        Style="{StaticResource BtnBase}" Background="#B71C1C"
                                        Padding="16,0" Height="36" Margin="16,0,0,0"
                                        Click="BtnLimpiarBD_Click"/>
                                </Grid>
                            </Border>

                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>

            <!-- BARRA DE BOTONES -->
            <StackPanel Grid.Row="5" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Style="{StaticResource BtnStyle}" Content="Probar Email"
                    Width="120" Background="#2E86C1" Margin="0,0,8,0"
                    Click="BtnTestEmail_Click"/>
                <Button Style="{StaticResource BtnStyle}" Content="Probar Telegram"
                    Width="140" Background="#0088CC" Margin="0,0,8,0"
                    Click="BtnTestTelegram_Click"/>
                <Button Style="{StaticResource BtnStyle}" Content="Guardar"
                    Width="100" Background="#1A8754" Margin="0,0,8,0"
                    Click="BtnGuardar_Click"/>
                <Button Style="{StaticResource BtnStyle}" Content="Cerrar"
                    Width="90" Background="#6C757D"
                    Click="BtnCerrar_Click"/>
            </StackPanel>

        </Grid>
    </ScrollViewer>
</Window>